# API protection (optional but recommended in production)
# Clients must send this in the X-Api-Secret header or ?secret= query param
API_SECRET=your_random_secret_here

# Twitter auth — option 1: cookies (preferred, more stable)
# Export as JSON array from browser (e.g. "EditThisCookie" extension), paste the full JSON string
TWITTER_COOKIES=

# Twitter auth — option 2: username/password (used when TWITTER_COOKIES is empty)
TWITTER_USERNAME=your_twitter_username
TWITTER_PASSWORD=your_twitter_password
TWITTER_EMAIL=your_twitter_email@example.com

# Server
PORT=3000

# Filtering
MIN_FOLLOWERS=1000          # Only include tweets from accounts with >= this many followers

# Tuning
BUFFER_SIZE=200             # Max tweets to keep in memory buffer
POLL_INTERVAL_MS=3000       # How often to fetch new tweets (ms)
PROFILE_CACHE_TTL_MS=3600000  # How long to cache user profiles (1 hour)
